---
import { pricing } from '../data/pricing';

const services = [
  {
    key: 'voiceAI',
    name: pricing.voiceAI.name,
    href: '/services/voice-ai/',
    setupLabel: pricing.voiceAI.setupLabel,
    monthlyLabel: pricing.voiceAI.monthlyLabel,
    description: "Your phone rings at 9pm on a Saturday. Right now, that call goes to voicemail — and the lead calls your competitor instead. An AI voice agent answers every call, qualifies the lead, books the appointment, and sends a follow-up text. All without you lifting a finger.",
    deliverables: [
      "24/7 call answering — no voicemail, no missed leads",
      "Lead qualification and intake scripted to your business",
      "Appointment booking synced to your calendar",
      "Automated SMS follow-up after every call",
      "Call transcripts and lead summaries delivered daily",
    ],
  },
  {
    key: 'reputation',
    name: pricing.reputation.name,
    href: '/services/reputation/',
    setupLabel: pricing.reputation.setupLabel,
    monthlyLabel: pricing.reputation.monthlyLabel,
    description: "Most satisfied clients never leave a review — not because they don't want to, but because no one asked at the right moment. We build the automated system that does: post-transaction requests, gentle follow-ups, and a monitoring dashboard so you always know what's being said about your business.",
    deliverables: [
      "Automated review request sequences via SMS and email",
      "Timed follow-ups for non-responders",
      "Google Business Profile monitoring and alert setup",
      "Negative review response guidance and templates",
      "Monthly reputation summary report",
    ],
  },
  {
    key: 'aeoSeo',
    name: pricing.aeoSeo.name,
    href: '/services/aeo-seo/',
    setupLabel: pricing.aeoSeo.oneTimeLabel + " one-time",
    monthlyLabel: pricing.aeoSeo.monthlyLabel,
    description: "ChatGPT, Google AI Overview, and Perplexity are answering buyer questions directly — and citing specific sources. We structure your content and schema so your business is the answer those AI engines pull. Combined with local SEO fundamentals, this is how you stay visible as search behavior shifts.",
    deliverables: [
      "AEO content audit and structured data implementation",
      "FAQ and service page content optimized for AI citation",
      "Local SEO foundation: NAP consistency, citations, GBP",
      "Schema markup: ProfessionalService, FAQPage, LocalBusiness",
      "Optional monthly retainer for ongoing content and optimization",
    ],
  },
];
---

<section class="section section-services" id="services">
  <div class="container">

    <div class="services-header">
      <p class="section-eyebrow">What We Build</p>
      <h2 class="services-headline">Three systems. One team. All running while you close deals.</h2>
    </div>

    <div class="services-list">
      {services.map((service, i) => (
        <div class="service-card">
          <div class="service-card-inner">
            <div class="service-meta">
              <span class="service-number">{i + 1}</span>
              <div class="service-pricing">
                <span class="service-monthly">{service.monthlyLabel}</span>
                <span class="service-setup">{service.setupLabel}</span>
              </div>
            </div>

            <div class="service-body">
              <h3 class="service-name">
                <a href={service.href}>{service.name}</a>
              </h3>
              <p class="service-description">{service.description}</p>

              <ul class="service-deliverables">
                {service.deliverables.map(item => (
                  <li>{item}</li>
                ))}
              </ul>

              <a href="/contact/" class="service-cta">Get started →</a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="services-footer">
      <p class="services-bundle-note">Need all three? The <strong>Full Growth Bundle</strong> combines every service starting at {pricing.bundle.monthlyLabel} ({pricing.bundle.setupLabel}).</p>
      <a href="/contact/" class="btn-primary">Talk to us about the bundle</a>
    </div>

  </div>
</section>

<style>
  .services-header {
    max-width: 680px;
    margin-bottom: 3rem;
  }

  .section-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
    max-width: none;
  }

  .services-headline {
    font-size: clamp(26px, 3vw, 42px);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.025em;
    color: var(--color-text);
  }

  /* ------------------------------------------------------------------ */
  /* Service cards                                                        */
  /* ------------------------------------------------------------------ */
  .services-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
  }

  .service-card {
    border-bottom: 1px solid var(--color-border);
  }

  .service-card:last-child {
    border-bottom: none;
  }

  .service-card-inner {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 0;
  }

  /* Left meta column */
  .service-meta {
    padding: 2.5rem 2rem;
    border-right: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
  }

  .service-number {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .service-pricing {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .service-monthly {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-accent);
    max-width: none;
  }

  .service-setup {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    max-width: none;
  }

  /* Right body column */
  .service-body {
    padding: 2.5rem;
  }

  .service-name {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 0.875rem;
  }

  .service-name a {
    text-decoration: none;
    color: inherit;
    transition: color 0.15s ease;
  }

  .service-name a:hover {
    color: var(--color-accent);
  }

  .service-description {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 62ch;
    margin-bottom: 1.5rem;
  }

  .service-deliverables {
    list-style: none;
    margin: 0 0 1.75rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-deliverables li {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }

  .service-deliverables li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  .service-cta {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: opacity 0.15s ease;
  }

  .service-cta:hover {
    opacity: 0.7;
  }

  /* ------------------------------------------------------------------ */
  /* Bundle footer                                                        */
  /* ------------------------------------------------------------------ */
  .services-footer {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .services-bundle-note {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    max-width: 52ch;
  }

  .services-bundle-note strong {
    color: var(--color-text);
    font-weight: 700;
  }

  /* ------------------------------------------------------------------ */
  /* Tablet                                                               */
  /* ------------------------------------------------------------------ */
  @media (max-width: 900px) {
    .service-card-inner {
      grid-template-columns: 1fr;
    }

    .service-number {
      display: none;
    }

    .service-setup {
      display: none;
    }

    .service-card {
      border-top: none;
      border-bottom: none;
    }

    .service-meta {
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      border-top: none;
      border-right: none;
      border-bottom: none;
      padding: 1.25rem 1.5rem;
      gap: 0;
    }

    .service-pricing {
      flex-direction: row;
      align-items: baseline;
      gap: 0.75rem;
    }

    .service-body {
      padding: 1.5rem;
    }
  }

  /* ------------------------------------------------------------------ */
  /* Mobile                                                               */
  /* ------------------------------------------------------------------ */
  @media (max-width: 768px) {
    .services-header {
      margin-bottom: 2rem;
    }

    .services-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 414px) {
    .service-meta {
      padding: 1rem;
    }

    .service-body {
      padding: 1.25rem 1rem;
    }

    .service-pricing {
      flex-direction: column;
      gap: 0.1rem;
    }
  }
</style>
