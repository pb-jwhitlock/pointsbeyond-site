<section class="hero">
  <div class="container hero-inner">

    <div class="hero-content">
      <p class="hero-eyebrow">AI Systems for Small Business</p>

      <h1 class="hero-headline">
        Never Miss a Lead.<br />
        Be the Answer<br />
        AI Delivers.
      </h1>

      <p class="hero-sub">
        Points Beyond AI builds the systems that answer every call, generate consistent Google reviews, and put your business in front of customers searching on ChatGPT, Google AI Overview, and Perplexity — all running automatically in the background while you work, including emergency call detection and routing.
      </p>

      <div class="hero-ctas">
        <a href="/contact/" class="btn-primary">Book a Free Strategy Call</a>
        <a href="/#process" class="hero-link-secondary">See how it works →</a>
      </div>

    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="service-stack">

        <div class="service-pill">
          <svg class="pill-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M2.25 6.338c0-1.243 1.016-2.25 2.27-2.252l.047-.001a.75.75 0 0 1 .72.544l.813 2.846a.75.75 0 0 1-.217.795l-1.48 1.35a1.15 1.15 0 0 0-.23 1.373c.6 1.026 1.382 1.96 2.306 2.766.923.806 1.965 1.463 3.086 1.94a1.15 1.15 0 0 0 1.394-.43l1.226-1.582a.75.75 0 0 1 .82-.257l2.826.894a.75.75 0 0 1 .527.719v.048c-.002 1.254-1.009 2.27-2.252 2.27h-.047c-9.18-.034-16.593-7.44-16.617-16.615v-.004Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>AI Voice Agents</span>
          <span class="pill-sub">Never miss a call.</span>
        </div>

        <div class="service-pill">
          <svg class="pill-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Reputation Management</span>
          <span class="pill-sub">Own your reputation.</span>
        </div>

        <div class="service-pill">
          <svg class="pill-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>AEO + SEO</span>
          <span class="pill-sub">Be the answer.</span>
        </div>

      </div>
    </div>

  </div>

  <!-- Accent rule below hero content -->
  <div class="hero-rule-wrap container">
    <div class="hero-rule"></div>
  </div>
</section>

<style>
  .hero {
    padding-top: 60px;
    padding-bottom: 0;
    background: var(--color-bg);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 340px;
    align-items: stretch;
    gap: 4rem;
  }

  /* ------------------------------------------------------------------ */
  /* Content                                                              */
  /* ------------------------------------------------------------------ */
  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
    max-width: none;
  }

  .hero-headline {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 1.75rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 54ch;
    margin-bottom: 2.5rem;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .hero-link-secondary {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.15s ease;
  }

  .hero-link-secondary:hover {
    color: var(--color-accent);
  }

  /* ------------------------------------------------------------------ */
  /* Bottom accent rule                                                   */
  /* ------------------------------------------------------------------ */
  .hero-rule-wrap {
    margin-top: 80px;
  }

  .hero-rule {
    height: 1px;
    background: var(--color-border);
    width: 100%;
  }

  /* ------------------------------------------------------------------ */
  /* Service stack (right column)                                        */
  /* ------------------------------------------------------------------ */
  .hero-visual {
    display: flex;
    align-items: center;
    width: 100%;
  }

  .service-stack {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
  }

  .service-pill {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .pill-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .pill-sub {
    margin-left: auto;
    font-size: 0.8rem;
    font-style: italic;
    font-weight: 400;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* ------------------------------------------------------------------ */
  /* Tablet                                                               */
  /* ------------------------------------------------------------------ */
  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr 260px;
      gap: 3rem;
    }
  }

  @media (max-width: 900px) {
    .hero-headline {
      font-size: clamp(38px, 8vw, 64px);
    }
  }

  /* ------------------------------------------------------------------ */
  /* Mobile                                                               */
  /* ------------------------------------------------------------------ */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      display: none;
    }

    .hero {
      padding-top: 32px;
      padding-bottom: 0;
    }

    .hero-rule-wrap {
      margin-top: 48px;
    }

    .hero-sub {
      font-size: 1rem;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }
  }

  @media (max-width: 414px) {
    .hero-headline {
      font-size: clamp(34px, 9vw, 52px);
    }
  }

  @media (max-width: 375px) {
    .hero-headline {
      font-size: 34px;
    }
  }
</style>
