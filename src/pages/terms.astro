<style>
  .prose {
    max-width: 720px;
    padding-block: var(--section-padding);
  }

  .prose h1 {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 800;
    letter-spacing: -0.025em;
    margin-bottom: 0.5rem;
  }

  .last-updated {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    max-width: none;
  }

  .prose h2 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .prose p {
    font-size: 0.975rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    max-width: 68ch;
  }

  .prose ul {
    list-style: none;
    padding: 0;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .prose ul li {
    font-size: 0.975rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    padding-left: 1.25rem;
    position: relative;
  }

  .prose ul li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose strong {
    color: var(--color-text);
    font-weight: 600;
  }
</style>
